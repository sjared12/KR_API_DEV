# Core datasource configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kr_api
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Optional dedicated Square datasource (falls back to core datasource when omitted)
SQUARE_DATASOURCE_URL=
SQUARE_DATASOURCE_USERNAME=
SQUARE_DATASOURCE_PASSWORD=

# Admin credentials for the built-in dashboards
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme

# Feedback admin credentials (optional overrides)
FEEDBACK_ADMIN_USER=feedbackadmin
FEEDBACK_ADMIN_PASS=changeme

# Square API credentials
SQUARE_API_TOKEN=sq0atp-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=XXXXXXXXXXXX
SQUARE_APPLICATION_ID=sandbox-sq0idb-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Square webhook configuration
SQUARE_WEBHOOK_SIGNATURE_KEY=whsec-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_WEBHOOK_NOTIFICATION_URL=https://example.com/api/square/webhook

# Optional behavior flags
ORDER_DATE_TZ=America/Chicago
ORDER_DATE_FORMATS=MM/dd/yyyy,yyyy-MM-dd
GA_TICKET_PRICE=25.00
PRESSBOX_TRIGGER_TICKET_TYPES=TBD,VIP
